# Dockerfile.preview
# Builds and serves the AsciiDoc documentation using DSPublisher's dev server.

FROM node:24-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --ignore-scripts

COPY articles/ articles/
COPY dspublisher/ dspublisher/
COPY frontend/ frontend/

EXPOSE 8210

CMD ["npm", "run", "dspublisher:start"]
